# Copy to deploy/.env and fill in an RPC endpoint.
# Sepolia testnet (recommended for evaluation — free, safe):
CURRENT_ETH_NETWORK=sepolia
FULLNODE_URL=https://ethereum-sepolia-rpc.publicnode.com

# For a mainnet dry run instead, use:
# CURRENT_ETH_NETWORK=main
# FULLNODE_URL=https://ethereum-rpc.publicnode.com
